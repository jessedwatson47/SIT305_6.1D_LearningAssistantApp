<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/item_history_answers_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/task_background"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/item_history_metadata"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Thurs, 13 Jan | DSA"
                android:textColor="#40FEFEFE" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/item_history_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:text="X. Question Title"
                android:textColor="#fefefe"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/item_history_button_expand"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:layout_weight="0"
                android:background="@drawable/navigation_button"
                android:contentDescription="Expand"
                android:padding="8dp"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/chevron" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_history_expanded_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/item_history_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Example question text goes here. Example question here yes it is."
                android:textColor="#A1FEFEFE"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/item_history_answer1_circle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:tint="#fefefe"
                    app:srcCompat="@android:drawable/ic_notification_overlay" />

                <TextView
                    android:id="@+id/item_history_answer1_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="30"
                    android:gravity="center_vertical"
                    android:paddingLeft="4dp"
                    android:text="Answer 1"
                    android:textColor="#fefefe"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/item_history_answer1_aside"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="Your Answer"
                    android:textColor="#A1fefefe"
                    android:textSize="8sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/item_history_answer2_circle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:tint="#fefefe"
                    app:srcCompat="@android:drawable/ic_notification_overlay" />

                <TextView
                    android:id="@+id/item_history_answer2_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="30"
                    android:gravity="center_vertical"
                    android:paddingLeft="4dp"
                    android:text="Answer 2"
                    android:textColor="#fefefe"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/item_history_answer2_aside"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="Your Answer"
                    android:textColor="#A1fefefe"
                    android:textSize="8sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/item_history_answer3_circle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:tint="#fefefe"
                    app:srcCompat="@android:drawable/ic_notification_overlay" />

                <TextView
                    android:id="@+id/item_history_answer3_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="30"
                    android:gravity="center_vertical"
                    android:paddingLeft="4dp"
                    android:text="Answer 3"
                    android:textColor="#fefefe"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/item_history_answer3_aside"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="Your Answer"
                    android:textColor="#A1fefefe"
                    android:textSize="8sp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>